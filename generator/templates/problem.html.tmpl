<!DOCTYPE html>
<html lang="en" data-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ .Title }} - ceetcode</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,400&family=Literata:ital,opsz,wght@0,7..72,300;0,7..72,400;0,7..72,600;1,7..72,400&display=swap"
        rel="stylesheet">
    <link rel="apple-touch-icon" sizes="180x180" href="/favico/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favico/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favico/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <link href="./styles.css" rel="stylesheet">
    <script src="./script.js" defer></script>
    <script data-goatcounter="https://ceetcode.goatcounter.com/count"
        async src="//gc.zgo.at/count.js"></script>
</head>

<body>
    <div class="container">
        <nav>
            <div class="nav-left">
                <div class="logo"><span>c</span>eetcode<span class="cursor"></span></div>
                <div><a href="index.html" class="nav-back">&larr; all problems</a></div>
            </div>
            <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
                <svg class="icon-moon" viewBox="0 0 24 24">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                </svg>
                <svg class="icon-sun" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="5" />
                    <line x1="12" y1="1" x2="12" y2="3" />
                    <line x1="12" y1="21" x2="12" y2="23" />
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                    <line x1="1" y1="12" x2="3" y2="12" />
                    <line x1="21" y1="12" x2="23" y2="12" />
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                </svg>
            </button>
        </nav>

        <div class="problem-header">
            <div class="problem-number">Problem {{ .Number }}</div>
            <h1 class="problem-title-text">{{ .Title }}</h1>
            <div class="problem-meta">
                <span class="difficulty-badge {{ .Difficulty }}">{{ .DifficultyTitle }}</span>
                <div class="meta-tags">
                    {{- range .Tags }}<span class="tag">{{ . }}</span>{{ end }}
                </div>
                <div class="meta-links">
                    <a href="{{ .LeetcodeURL }}" target="_blank" rel="noopener" class="meta-link">
                        leetcode <svg viewBox="0 0 24 24">
                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                            <polyline points="15 3 21 3 21 9" />
                            <line x1="10" y1="14" x2="21" y2="3" />
                        </svg>
                    </a>
                    <a href="{{ .SourceURL }}"
                        target="_blank" rel="noopener" class="meta-link">
                        source <svg viewBox="0 0 24 24">
                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                            <polyline points="15 3 21 3 21 9" />
                            <line x1="10" y1="14" x2="21" y2="3" />
                        </svg>
                    </a>
                </div>
            </div>
        </div>

        <section class="section">
            <div class="section-label">Approach</div>
            {{ .Approach }}
        </section>

        <section class="section">
            <div class="section-label">Complexity</div>
            <div class="complexity-grid">
                <div class="complexity-item">
                    <span class="complexity-label">Time</span>
                    <span class="complexity-value">{{ .TimeComplexity }}</span>
                </div>
                <div class="complexity-item">
                    <span class="complexity-label">Space</span>
                    <span class="complexity-value">{{ .SpaceComplexity }}</span>
                </div>
            </div>
        </section>

        <section class="section">
            <div class="section-label">Solution</div>
            <div class="code-block">
                <div class="code-header">
                    <span class="code-filename">solution.c</span>
                    <div class="code-actions">
                        <a href="{{ .SourceURL }}"
                            target="_blank" rel="noopener" class="code-btn">
                            <svg viewBox="0 0 24 24">
                                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                                <polyline points="15 3 21 3 21 9" />
                                <line x1="10" y1="14" x2="21" y2="3" />
                            </svg>
                            raw
                        </a>
                        <button class="code-btn" onclick="copyCode()">
                            <svg class="copy-icon" viewBox="0 0 24 24">
                                <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                            </svg>
                            <span class="copy-text">copy</span>
                        </button>
                    </div>
                </div>
                <div class="code-body">
                    <pre>{{ .Code }}</pre>
                </div>
            </div>
        </section>

        <div class="problem-nav">
            {{- if .Prev }}
            <a href="{{ .Prev.Slug }}.html" class="prev-next prev">
                <span class="prev-next-label">&larr; Prev</span>
                <span class="prev-next-title">{{ .Prev.Number }}. {{ .Prev.Title }}</span>
            </a>
            {{- else }}
            <div></div>
            {{- end }}
            {{- if .Next }}
            <a href="{{ .Next.Slug }}.html" class="prev-next next">
                <span class="prev-next-label">Next &rarr;</span>
                <span class="prev-next-title">{{ .Next.Number }}. {{ .Next.Title }}</span>
            </a>
            {{- else }}
            <div></div>
            {{- end }}
        </div>

        <section class="section comments-section">
            <div class="section-label">Discussions</div>
            <script src="https://giscus.app/client.js"
                    data-repo="priyakdey/ceetcode"
                    data-repo-id="R_kgDONzIH4g"
                    data-category="Comments"
                    data-category-id="DIC_kwDONzIH4s4C8a2p"
                    data-mapping="pathname"
                    data-strict="0"
                    data-reactions-enabled="1"
                    data-emit-metadata="0"
                    data-input-position="top"
                    data-theme="preferred_color_scheme"
                    data-lang="en"
                    data-loading="lazy"
                    crossorigin="anonymous"
                    async>
            </script>
        </section>

        <footer>
            <div class="footer-top">
                <div class="footer-brand"><span>c</span>eetcode</div>
                <div class="social-icons">
                    <a href="https://github.com/priyakdey/ceetcode" target="_blank" rel="noopener" class="social-icon"
                        aria-label="GitHub">
                        <svg viewBox="0 0 24 24" fill="currentColor" stroke="none">
                            <path
                                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
                        </svg>
                    </a>
                    <a href="https://www.linkedin.com/in/priyakdey/" target="_blank" rel="noopener" class="social-icon"
                        aria-label="LinkedIn">
                        <svg viewBox="0 0 24 24" fill="currentColor" stroke="none">
                            <path
                                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                        </svg>
                    </a>
                    <a href="https://www.youtube.com/@priyak1991dey" target="_blank" rel="noopener" class="social-icon"
                        aria-label="YouTube">
                        <svg viewBox="0 0 24 24" fill="currentColor" stroke="none">
                            <path
                                d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
                        </svg>
                    </a>
                    <a href="https://leetcode.com/u/priyak1991dey/" target="_blank" rel="noopener" class="social-icon"
                        aria-label="LeetCode">
                        <svg viewBox="0 0 24 24" fill="currentColor" stroke="none">
                            <path
                                d="M13.483 0a1.374 1.374 0 0 0-.961.438L7.116 6.226l-3.854 4.126a5.266 5.266 0 0 0-1.209 2.104 5.35 5.35 0 0 0-.125.513 5.527 5.527 0 0 0 .062 2.362 5.83 5.83 0 0 0 .349 1.017 5.938 5.938 0 0 0 1.271 1.818l4.277 4.193.039.038c2.248 2.165 5.852 2.133 8.063-.074l2.396-2.392c.54-.54.54-1.414.003-1.955a1.378 1.378 0 0 0-1.951-.003l-2.396 2.392a3.021 3.021 0 0 1-4.205.038l-.02-.019-4.276-4.193c-.652-.64-.972-1.469-.948-2.263a2.68 2.68 0 0 1 .066-.523 2.545 2.545 0 0 1 .619-1.164L9.13 8.114c1.058-1.134 3.204-1.27 4.43-.278l3.501 2.831c.593.48 1.461.387 1.94-.207a1.384 1.384 0 0 0-.207-1.943l-3.5-2.831c-.8-.647-1.766-1.045-2.774-1.202l2.015-2.158A1.384 1.384 0 0 0 13.483 0zm-2.866 12.815a1.38 1.38 0 0 0-1.38 1.382 1.38 1.38 0 0 0 1.38 1.382H20.79a1.38 1.38 0 0 0 1.38-1.382 1.38 1.38 0 0 0-1.38-1.382z" />
                        </svg>
                    </a>
                </div>
            </div>
            <div class="footer-bottom">
                <span class="copyright">&copy; {{ .Year }} Priyak Dey. All rights reserved.</span>
                <span class="built-by">built by <a href="https://priyakdey.com" target="_blank"
                        rel="noopener">priyakdey</a></span>
            </div>
        </footer>

    </div>
</body>

</html>
